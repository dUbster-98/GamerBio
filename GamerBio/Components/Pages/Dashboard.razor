@page "/dashboard"
@rendermode InteractiveServer
@using System.Globalization
@using GamerBio.Hubs
@using GamerBio.Models
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Nav
@inject IConfiguration Config
@implements IAsyncDisposable

<PageTitle>Live Dashboard · GamerBio</PageTitle>

<div class="dash" style="--state: @StateColorVar(_tension?.State ?? TensionState.Calibrating);">

    <header class="dash-head">
        <div>
            <div class="hud-eyebrow">Live Telemetry</div>
            <h1 class="dash-title">Bio Dashboard</h1>
        </div>

        <div class="conn-pill @(IsConnected ? "is-on" : "is-off")">
            <span class="conn-dot"></span>
            <span class="mono">@(IsConnected ? "STREAM LIVE" : (_connection?.State.ToString().ToUpperInvariant() ?? "OFFLINE"))</span>
        </div>
    </header>

    <!-- ===== Camera + Tension ===== -->
    <section class="stage">

        <div class="hud-panel cam">
            <div class="cam-head">
                <span class="hud-eyebrow">Live Camera</span>
                <span class="cam-status mono @(_camUrl is null ? "off" : "on")">
                    <span class="cam-dot"></span>@(_camUrl is null ? "NO SOURCE" : "MJPEG")
                </span>
            </div>

            <div class="cam-stage">
                @if (_camUrl is not null)
                {
                    <img class="cam-feed" src="@_camUrl" alt="Live camera feed"
                         onerror="this.classList.add('errored')" />
                }
                <div class="cam-offline">
                    <div class="cam-offline-ico">📷</div>
                    <div class="cam-offline-txt mono">CAMERA OFFLINE</div>
                    <div class="cam-offline-sub mono">PC MJPEG 스트림 대기 중</div>
                </div>
                <div class="cam-scan" aria-hidden="true"></div>
                <div class="cam-corner tl"></div>
                <div class="cam-corner br"></div>
            </div>

            <div class="cam-foot">
                <span class="hud-eyebrow">Emotion</span>
                <span class="cam-emotion mono">
                    @if (_emotion is not null)
                    {
                        @($"{EmotionEmoji(_emotion.Dominant)} {_emotion.Dominant.ToUpperInvariant()} {EmotionPct(_emotion):0}%")
                    }
                    else
                    {
                        @("— 분석 대기")
                    }
                </span>
            </div>
        </div>

        <section class="hud-panel hero">
        <div class="hero-grid">
            <div class="hero-state">
                <div class="hud-eyebrow">Tension State</div>
                <div class="state-name">
                    <span class="state-emoji">@StateEmoji(_tension?.State ?? TensionState.Calibrating)</span>
                    @StateLabel(_tension?.State ?? TensionState.Calibrating)
                </div>

                <div class="ecg" aria-hidden="true">
                    <div class="ecg-line @(IsConnected ? "live" : "")"
                         style="--beat: @BeatDuration"></div>
                </div>
            </div>

            <div class="hero-score">
                <div class="score-num mono">@(_tension?.Score ?? 0)<span class="score-max">/100</span></div>
                <div class="hud-eyebrow">Composite Index</div>
            </div>
        </div>

        <div class="gauge">
            <div class="gauge-fill" style="width: @((_tension?.Score ?? 0))%;"></div>
            <span class="gauge-tick" style="left:30%"></span>
            <span class="gauge-tick" style="left:65%"></span>
        </div>

        <div class="contrib">
            <div class="contrib-item">
                <span class="contrib-label mono">BPM</span>
                <span class="contrib-val mono">@(_tension?.BpmScore ?? 0)</span>
            </div>
            <div class="contrib-item">
                <span class="contrib-label mono">GSR</span>
                <span class="contrib-val mono">@(_tension?.GsrScore ?? 0)</span>
            </div>
            <div class="contrib-item">
                <span class="contrib-label mono">LOW-VAR</span>
                <span class="contrib-val mono">@(_tension?.LowVariabilityScore ?? 0)</span>
            </div>
            <div class="contrib-item">
                <span class="contrib-label mono">EMOTION</span>
                <span class="contrib-val mono">@(_tension?.EmotionScore ?? 0)</span>
            </div>
        </div>
        </section>
    </section>

    <!-- ===== Vitals ===== -->
    <section class="vitals">
        <div class="hud-panel vital v-heart">
            <div class="vital-top">
                <span class="hud-eyebrow">Heart Rate</span>
                <span class="vital-heart" style="--beat: @BeatDuration">♥</span>
            </div>
            <div class="vital-num mono">@(_latest?.Bpm.ToString() ?? "––")</div>
            <div class="vital-unit mono">BPM</div>
        </div>

        <div class="hud-panel vital v-gsr">
            <div class="vital-top">
                <span class="hud-eyebrow">Skin Conductance</span>
            </div>
            <div class="vital-num mono">@(_latest?.Gsr.ToString() ?? "––")</div>
            <div class="vital-unit mono">µS · GSR</div>
        </div>

        <div class="hud-panel vital v-temp">
            <div class="vital-top">
                <span class="hud-eyebrow">Skin Temp</span>
            </div>
            <div class="vital-num mono">@(_latest?.SkinTemp?.ToString("F1") ?? "––")</div>
            <div class="vital-unit mono">°C</div>
        </div>

        <div class="hud-panel vital v-time">
            <div class="vital-top">
                <span class="hud-eyebrow">Last Packet</span>
            </div>
            <div class="vital-num vital-time mono">@(_latest?.Timestamp.LocalDateTime.ToString("HH:mm:ss") ?? "--:--:--")</div>
            <div class="vital-unit mono">@(_recent.Count) samples buffered</div>
        </div>
    </section>

    <!-- ===== Feed ===== -->
    <section class="hud-panel feed">
        <div class="feed-head">
            <span class="hud-eyebrow">Incoming Stream</span>
            <span class="feed-meta mono">last @MaxRecent</span>
        </div>

        @if (_recent.Count == 0)
        {
            <div class="feed-empty mono">
                awaiting packets · <code>POST /api/biosignal</code>
            </div>
        }
        else
        {
            <table class="feed-table mono">
                <thead>
                    <tr>
                        <th>TIME</th>
                        <th>BPM</th>
                        <th>GSR</th>
                        <th>TEMP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _recent)
                    {
                        <tr>
                            <td class="t-time">@item.Timestamp.LocalDateTime.ToString("HH:mm:ss")</td>
                            <td class="t-heart">@item.Bpm</td>
                            <td class="t-gsr">@item.Gsr</td>
                            <td class="t-temp">@(item.SkinTemp?.ToString("F1") ?? "–")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private const int MaxRecent = 20;

    private HubConnection? _connection;
    private BioSignal? _latest;
    private TensionReading? _tension;
    private EmotionReading? _emotion;
    private readonly LinkedList<BioSignal> _recent = new();

    // PC MJPEG stream URL (e.g. http://192.168.0.50:8080). Null when unconfigured.
    private string? _camUrl;

    private bool IsConnected => _connection?.State == HubConnectionState.Connected;

    // Drive the heartbeat animation speed from the live BPM (seconds per beat).
    private string BeatDuration =>
        (_latest is { Bpm: > 0 } s ? (60.0 / s.Bpm) : 1.0)
            .ToString("0.000", CultureInfo.InvariantCulture) + "s";

    protected override async Task OnInitializedAsync()
    {
        var cam = Config["Camera:StreamUrl"];
        _camUrl = string.IsNullOrWhiteSpace(cam) ? null : cam;

        _connection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri(BioSignalHub.Path))
            .WithAutomaticReconnect()
            .Build();

        _connection.On<BioSignal>(BioSignalHub.BioSignalReceived, async signal =>
        {
            _latest = signal;
            _recent.AddFirst(signal);
            while (_recent.Count > MaxRecent)
            {
                _recent.RemoveLast();
            }
            await InvokeAsync(StateHasChanged);
        });

        _connection.On<TensionReading>(BioSignalHub.TensionUpdated, async reading =>
        {
            _tension = reading;
            await InvokeAsync(StateHasChanged);
        });

        _connection.On<EmotionReading>(BioSignalHub.EmotionUpdated, async reading =>
        {
            _emotion = reading;
            await InvokeAsync(StateHasChanged);
        });

        _connection.Reconnected += _ => InvokeAsync(StateHasChanged);
        _connection.Closed += _ => InvokeAsync(StateHasChanged);

        await _connection.StartAsync();
        await InvokeAsync(StateHasChanged);
    }

    private static string StateLabel(TensionState state) => state switch
    {
        TensionState.Calibrating => "Calibrating",
        TensionState.Relaxed => "Relaxed",
        TensionState.Focused => "Focused",
        TensionState.Stressed => "Stressed",
        TensionState.Deadly => "Deadly",
        _ => state.ToString(),
    };

    private static string StateEmoji(TensionState state) => state switch
    {
        TensionState.Calibrating => "⏳",
        TensionState.Relaxed => "😏",
        TensionState.Focused => "🥵",
        TensionState.Stressed => "😱",
        TensionState.Deadly => "☠️",
        _ => string.Empty,
    };

    private static double EmotionPct(EmotionReading e) =>
        e.Scores.TryGetValue(e.Dominant, out var v) ? v : 0;

    private static string EmotionEmoji(string emotion) => emotion switch
    {
        "angry" => "😠",
        "fear" => "😱",
        "happy" => "😄",
        "surprise" => "😲",
        "neutral" => "😐",
        _ => "😐",
    };

    private static string StateColorVar(TensionState state) => state switch
    {
        TensionState.Relaxed => "var(--st-relaxed)",
        TensionState.Focused => "var(--st-focused)",
        TensionState.Stressed => "var(--st-stressed)",
        TensionState.Deadly => "var(--st-deadly)",
        _ => "var(--st-calibrating)",
    };

    public async ValueTask DisposeAsync()
    {
        if (_connection is not null)
        {
            await _connection.DisposeAsync();
        }
    }
}
