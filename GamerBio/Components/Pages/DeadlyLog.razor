@page "/event"
@rendermode InteractiveServer
@using System.Globalization
@using GamerBio.Data
@using GamerBio.Hubs
@using GamerBio.Models
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Event Log · GamerBio</PageTitle>

<div class="deadly">

    <header class="dl-head">
        <div>
            <div class="hud-eyebrow">THREAT Archive</div>
            <h1 class="dl-title">☠️ Event Log</h1>
        </div>
        <div class="dl-count mono">@Displayed.Count EVENTS</div>
    </header>

    @if (_all.Count == 0)
    {
        <section class="hud-panel dl-empty mono">
            아직 기록된 이벤트가 없습니다
        </section>
    }
    else
    {
        <!-- ===== Date filter ===== -->
        <nav class="dl-dates">
            <button class="dl-date @(_selectedDate is null ? "active" : "")"
                    @onclick="() => SelectDate(null)">
                <span class="dl-date-day mono">전체</span>
                <span class="dl-date-full mono">ALL</span>
            </button>
            @foreach (var d in _dates)
            {
                <button class="dl-date @(_selectedDate == d ? "active" : "")"
                        @onclick="() => SelectDate(d)">
                    <span class="dl-date-day mono">@d.ToString("MM-dd")</span>
                    <span class="dl-date-full mono">@d.ToString("yyyy · ddd", CultureInfo.InvariantCulture)</span>
                </button>
            }
        </nav>

        @if (Displayed.Count == 0)
        {
            <section class="hud-panel dl-empty mono">
                이 날짜에 기록된 이벤트가 없습니다
            </section>
        }
        else
        {
        <section class="dl-list">
            @foreach (var e in Displayed)
            {
                <article class="hud-panel row">
                    <div class="row-top">
                        <div class="row-score mono">
                            <strong>@e.Score</strong><small>/100</small>
                        </div>

                        <div class="row-vitals mono">
                            <div class="row-time mono">@e.OccurredAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</div>
                            <span class="v-bpm">♥ @e.Bpm BPM</span>
                            <span class="v-gsr">GSR @e.Gsr</span>
                            <span class="v-emo">@(e.DominantEmotion ?? "—")</span>
                        </div>
                    </div>

                    <div class="row-main">                     
                        <div class="row-factors">
                            @foreach (var (label, val) in Factors(e))
                            {
                                <div class="factor">
                                    <span class="f-label mono">@label</span>
                                    <span class="f-bar"><span class="f-fill" style="width:@(val)%"></span></span>
                                    <span class="f-val mono">@val</span>
                                </div>
                            }
                        </div>
                    </div>
                </article>
            }
        </section>
        }
    }
</div>

@code {
    private const int MaxRows = 500;

    // All loaded events (newest first). Deadly entries are rare, so we hold the
    // full set client-side and filter by date in memory rather than re-querying.
    private readonly List<DeadlyEvent> _all = new();
    private DateOnly? _selectedDate;   // null = show everything
    private HubConnection? _connection;

    // Distinct local dates that have events, newest first (for the filter chips).
    private IReadOnlyList<DateOnly> _dates = Array.Empty<DateOnly>();

    // Events matching the current date filter (or all when no date is selected).
    private List<DeadlyEvent> Displayed =>
        _selectedDate is DateOnly d
            ? _all.Where(e => LocalDate(e) == d).ToList()
            : _all;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();

        // Live-prepend Deadly entries as the server records them.
        _connection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri(BioSignalHub.Path))
            .WithAutomaticReconnect()
            .Build();

        _connection.On<DeadlyEvent>(BioSignalHub.DeadlyEventRecorded, async e =>
        {
            if (_all.All(x => x.Id != e.Id))
            {
                _all.Insert(0, e);
                RebuildDates();
                await InvokeAsync(StateHasChanged);
            }
        });

        await _connection.StartAsync();
    }

    private async Task ReloadAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<BioMonitorContext>();
        var items = await db.DeadlyEvents
            .OrderByDescending(x => x.OccurredAt)
            .Take(MaxRows)
            .ToListAsync();
        _all.Clear();
        _all.AddRange(items);
        RebuildDates();
    }

    private void SelectDate(DateOnly? date) => _selectedDate = date;

    private void RebuildDates() =>
        _dates = _all
            .Select(LocalDate)
            .Distinct()
            .OrderDescending()
            .ToList();

    // Group by the same local date shown on each row (OccurredAt is stored UTC).
    private static DateOnly LocalDate(DeadlyEvent e) =>
        DateOnly.FromDateTime(e.OccurredAt.LocalDateTime);

    private static IEnumerable<(string Label, int Value)> Factors(DeadlyEvent e)
    {
        yield return ("BPM", e.BpmScore);
        yield return ("GSR", e.GsrScore);
        yield return ("VAR", e.LowVariabilityScore);
        yield return ("EMO", e.EmotionScore);
    }

    public async ValueTask DisposeAsync()
    {
        if (_connection is not null)
        {
            await _connection.DisposeAsync();
        }
    }
}
